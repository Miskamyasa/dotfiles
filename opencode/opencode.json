{
    "$schema": "https://opencode.ai/config.json",
    "agent": {
        "build": {
            "model": "anthropic/claude-opus-4-5",
            "temperature": 0
        },
        "explore": {
            "model": "google/gemini-3-flash-preview",
            "temperature": 0
        },
        "general": {
            "model": "openai/gpt-5.3-codex",
            "temperature": 0
        },
        "investigate": {
            "model": "openai/gpt-5.3-codex",
            "temperature": 0
        },
        "plan": {
            "model": "anthropic/claude-opus-4-5",
            "temperature": 0
        },
        "review": {
            "model": "openai/gpt-5.2",
            "temperature": 0
        }
    },
    "autoupdate": false,
    "default_agent": "investigate",
    "disabled_providers": [
        "opencode"
    ],
    "formatter": false,
    "lsp": false,
    "mcp": {},
    "plugin": [],
    "provider": {},
    "share": "disabled",
    "small_model": "anthropic/claude-haiku-4-5",
    "snapshot": false,
    "theme": "system",
    "tui": {
        "diff_style": "stacked"
    },
    "watcher": {
        "ignore": [
            "node_modules/**",
            "dist/**",
            ".git/**"
        ]
    }
}