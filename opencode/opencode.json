{
    "$schema": "https://opencode.ai/config.json",
    "agent": {
        "build": {
            "model": "anthropic/claude-opus-4-6",
            "temperature": 0,
            "reasoningEffort": "high"
        },
        "explore": {
            "model": "google/gemini-3-flash-preview",
            "temperature": 0,
            "reasoningEffort": "low"
        },
        "general": {
            "model": "anthropic/claude-sonnet-4-6",
            "temperature": 0,
            "reasoningEffort": "high"
        },
        "investigate": {
            "model": "openai/gpt-5.3-codex",
            "temperature": 0,
            "reasoningEffort": "high"
        },
        "plan": {
            "model": "anthropic/claude-opus-4-6",
            "temperature": 0,
            "reasoningEffort": "high"
        },
        "review": {
            "model": "openai/gpt-5.2",
            "temperature": 0,
            "reasoningEffort": "high"
        }
    },
    "autoupdate": false,
    "default_agent": "investigate",
    "disabled_providers": [
        "opencode"
    ],
    "formatter": false,
    "lsp": false,
    "mcp": {
        "figma": {
            "enabled": false,
            "type": "remote",
            "url": "http://host.docker.internal:3845/mcp"
        },
        "jetbrains": {
            "enabled": false,
            "headers": {
                "Host": "localhost:64342",
                "Origin": "http://localhost"
            },
            "type": "remote",
            "url": "http://host.docker.internal:64342/sse"
        }
    },
    "plugin": [],
    "provider": {},
    "share": "disabled",
    "small_model": "anthropic/claude-haiku-4-5",
    "snapshot": false,
    "theme": "system",
    "tui": {
        "diff_style": "stacked"
    },
    "watcher": {
        "ignore": [
            "node_modules/**",
            "dist/**",
            ".git/**"
        ]
    }
}